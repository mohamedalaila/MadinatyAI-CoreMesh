// ──────────────────────────────────────────────────────────────
// MadinatyAI Ecosystem Hub — Prisma schema
// Multi-tenant via SEPARATE PostgreSQL schemas (multiSchema).
//   - "core"          : shared identity / reputation / ledger
//   - "tenant_*"      : per-app isolated schemas (souq/kitchen/tutor/timebank)
// pgvector enabled for semantic cross-matching embeddings.
// Transparent Broker: NO financial/transaction models. Payment
// handles live only as raw strings inside GlobalUser.metadata.
// ──────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
  schemas    = ["core", "tenant_souq", "tenant_kitchen", "tenant_tutor", "tenant_timebank", "tenant_soukelkanto", "tenant_life", "tenant_express"]
}

// ─────────────── Enums (core schema) ───────────────

enum Role {
  USER
  PROVIDER
  TENANT_ADMIN
  PLATFORM_ADMIN

  @@schema("core")
}

enum TenantTier {
  FREE
  STANDARD
  PREMIUM

  @@schema("core")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("core")
}

enum IncidentType {
  FRAUD
  SCAM
  ABUSE
  SPAM
  IMPERSONATION
  POLICY_VIOLATION
  OTHER

  @@schema("core")
}

// ─────────────── Core shared models ───────────────

model GlobalUser {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  isVerified  Boolean  @default(false)
  trustScore  Int      @default(100)
  role        Role     @default(USER)
  // Raw payment handles (Instapay / Vodafone Cash) + arbitrary profile data.
  // Stored as opaque metadata only — Transparent Broker policy.
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kyc             KycRegistry?
  semanticProfile SemanticProfile?
  tokenWallet     TokenWallet?
  reportsMade     EcosystemSharedReport[] @relation("ReporterRelation")
  reportsReceived EcosystemSharedReport[] @relation("OffenderRelation")
  pushDevices     PushDeviceToken[]

  @@index([trustScore])
  @@schema("core")
}

/// FCM push-notification device tokens. Cross-tenant: a user may have
/// tokens for multiple devices/apps. The `platform` field segments
/// web vs. mobile for payload optimisation.
model PushDeviceToken {
  id          String   @id @default(uuid())
  userId      String   // FK → core.GlobalUser
  token       String   @unique
  platform    String   @db.VarChar(20)  // "web" | "android" | "ios"
  appSlug     String?  @db.VarChar(40)  // tenant subdomain, nullable for global
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user GlobalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([appSlug])
  @@map("push_device_tokens")
  @@schema("core")
}

model Tenant {
  id         String     @id @default(uuid())
  // App subdomain, e.g. "souq", "kitchen", "tutor", "timebank".
  subdomain  String     @unique
  // Physical PostgreSQL schema pointer, e.g. "tenant_souq".
  schemaName String     @unique
  isActive   Boolean    @default(true)
  tierLevel  TenantTier @default(FREE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([isActive])
  @@schema("core")
}

model KycRegistry {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          GlobalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Path/key to AES-256-GCM encrypted ID document (never the raw doc).
  encryptedIdPath String
  idNumber      String
  status        KycStatus @default(PENDING)
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@schema("core")
}

model EcosystemSharedReport {
  id                  String       @id @default(uuid())
  reporterId          String
  offenderId          String
  reporter            GlobalUser   @relation("ReporterRelation", fields: [reporterId], references: [id])
  offender            GlobalUser   @relation("OffenderRelation", fields: [offenderId], references: [id])
  incidentType        IncidentType
  // 1 (minor) .. 5 (critical) — feeds the cross-platform TrustScore.
  severity            Int          @default(1)
  isPlatformWideBanned Boolean     @default(false)
  // Subdomain where the incident originated (souq/kitchen/...).
  originSubdomain     String?
  createdAt           DateTime     @default(now())

  @@index([offenderId])
  @@index([incidentType])
  @@schema("core")
}

// Global ledger populated by the cross-platform event system for analytics.
model EcosystemCrossMatches {
  id              String   @id @default(uuid())
  userId          String?
  sourceSubdomain String
  eventType       String
  payload         Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([sourceSubdomain])
  @@index([eventType])
  @@schema("core")
}

// Semantic embeddings for cross-platform matching (cloud-generated via Gemini).
model SemanticProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      GlobalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 768-dim vector (pgvector). Read/written via raw SQL helpers.
  embedding Unsupported("vector(768)")?
  updatedAt DateTime @updatedAt

  @@schema("core")
}

// ─────────────── Token Wallet (core schema) ───────────────

model TokenWallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             GlobalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessTokens   Int      @default(0)
  individualTokens Int      @default(0)

  allocations      TokenAllocation[]
  transactions     TokenTransaction[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@schema("core")
}

model TokenAllocation {
  id             String   @id @default(uuid())
  walletId       String
  wallet         TokenWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  activityType   String
  tokenType      String   // "business" | "individual"
  allocatedAmount Int     @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([walletId, activityType, tokenType])
  @@schema("core")
}

model TokenTransaction {
  id          String   @id @default(uuid())
  walletId    String
  wallet      TokenWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  activityType String
  tokenType    String  // "business" | "individual"
  amount       Int     // Positive = credit, negative = debit

  description  String?
  referenceId  String?

  createdAt    DateTime @default(now())

  @@index([walletId, createdAt])
  @@schema("core")
}

model ActivityPricing {
  id          String   @id @default(uuid())
  activityType String  @unique
  cost        Int
  description String
  isActive    Boolean @default(true)
  updatedAt   DateTime @updatedAt

  @@schema("core")
}

// ─────────────── Auth: OTP Challenges ───────────────
// Short-lived one-time-password records for phone-based auth.
// Phase A.1 — Postgres-backed (no Redis dep). TTL enforced via expiresAt
// + nightly cleanup cron. codeHash = sha256(`${phoneNumber}:${code}`).
model OtpChallenge {
  id            String    @id @default(uuid())
  phoneNumber   String
  codeHash      String
  purpose       String    @default("LOGIN") // LOGIN | REGISTER
  expiresAt     DateTime
  consumedAt    DateTime?
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([phoneNumber, createdAt])
  @@index([expiresAt])
  @@schema("core")
}

// ─────────────── Per-tenant placeholder models ───────────────
// Minimal tables so each tenant schema physically exists and
// isolation can be verified. Each ecosystem app extends its own schema later.

model SouqListing {
  id                String   @id @default(uuid())
  ownerGlobalUserId String
  title             String
  createdAt         DateTime @default(now())

  @@schema("tenant_souq")
}

model KitchenBusiness {
  id              String   @id @default(uuid())
  ownerGlobalUserId String
  slug            String   @unique   // "ali-kitchen" → ali.kitchen.madinatyai.com
  name            String
  isActive        Boolean  @default(true)
  status          String   @default("PENDING")

  // Visual identity (logo, colors, fonts, hero image, custom CSS, social links)
  branding        Json     @default("{}")

  // Business profile
  description     String?
  cuisineType     String?   // "Egyptian", "Asian", etc.
  address         String?
  phone           String?
  openingHours    Json?     // { "mon": "9-22", "tue": "9-22", ... }

  menuItems       KitchenMenuItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerGlobalUserId])
  @@index([isActive])
  @@schema("tenant_kitchen")
}

model KitchenMenuItem {
  id          String   @id @default(uuid())
  businessId  String
  business    KitchenBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String?
  price       Float?
  category    String?    // "Main", "Appetizer", "Drinks"
  imageUrl    String?
  isAvailable Boolean  @default(true)
  scheduleType String   @default("ALL_DAY")
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@schema("tenant_kitchen")
}

model TutorBusiness {
  id              String   @id @default(uuid())
  ownerGlobalUserId String
  slug            String   @unique   // "ahmed-tutor" → ahmed.tutor.madinatyai.com
  name            String
  isActive        Boolean  @default(true)

  // Visual identity (logo, colors, fonts, hero image, custom CSS, social links)
  branding        Json     @default("{}")

  // Business profile
  description     String?
  subjects        String[]  // ["Math", "Physics", "Arabic"]
  qualifications  String?
  hourlyRate      Float?
  address         String?
  phone           String?
  availability    Json?     // { "mon": ["9-12","14-18"], ... }

  bookings        TutorBooking[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerGlobalUserId])
  @@index([isActive])
  @@schema("tenant_tutor")
}

model TutorBooking {
  id          String   @id @default(uuid())
  businessId  String
  business    TutorBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  studentId   String   // GlobalUser.id of the student
  title       String
  subject     String?
  scheduledAt DateTime?
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  notes       String?
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([studentId])
  @@schema("tenant_tutor")
}

model TimeBankOffer {
  id                String   @id @default(uuid())
  ownerGlobalUserId String
  title             String
  createdAt         DateTime @default(now())

  @@schema("tenant_timebank")
}

// =====================================================
// tenant_soukelkanto — Souk ElKanto P2P marketplace
// =====================================================

model SoukListing {
  id            String            @id @default(uuid())
  sellerId      String                                        // FK → core.GlobalUser
  title         String            @db.VarChar(120)
  description   String            @db.Text
  category      SoukCategory
  condition     SoukCondition
  askingPrice   Int                                           // EGP, integer
  currency      String            @default("EGP") @db.VarChar(3)
  district      String            @db.VarChar(64)
  status        SoukListingStatus @default(ACTIVE)
  isPhotoStale  Boolean           @default(false)
  embedding     Unsupported("vector(768)")?                     // pgvector
  viewCount     Int               @default(0)
  favoriteCount Int               @default(0)
  boostedUntil  DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  removedAt     DateTime?

  photos    SoukListingPhoto[]
  offers    SoukOffer[]
  favorites SoukFavorite[]

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@index([district])
  @@index([createdAt])
  @@map("listings")
  @@schema("tenant_soukelkanto")
}

model SoukListingPhoto {
  id          String      @id @default(uuid())
  listingId   String
  r2Key       String      @db.VarChar(256)
  url         String      @db.VarChar(512)
  width       Int
  height      Int
  bytes       Int
  phash       String?     @db.VarChar(64)
  exifTakenAt DateTime?
  uploadedAt  DateTime    @default(now())
  position    Int         @default(0)

  listing SoukListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, position])
  @@index([phash])
  @@map("listing_photos")
  @@schema("tenant_soukelkanto")
}

model SoukOffer {
  id                 String          @id @default(uuid())
  listingId          String
  buyerId            String                                        // FK → core.GlobalUser
  sellerId           String                                        // FK → core.GlobalUser
  amount             Int                                           // EGP offered
  note               String?         @db.Text
  status             SoukOfferStatus @default(PENDING)
  parentOfferId      String?
  tokenHoldAmount    Int?
  tokenHoldExpiresAt DateTime?
  acceptedAt         DateTime?
  declinedAt         DateTime?
  withdrawnAt        DateTime?
  expiredAt          DateTime?
  // Reason a non-PENDING terminal state was reached. Free-form snake_case tag
  // produced by the BE — e.g. "auto_declined_listing_sold" (R-01 cascade),
  // "listing_removed_by_seller" (R-08), or a user-supplied decline message.
  // FE can localize using a key map.
  declineReason      String?         @db.VarChar(80)
  safeMeetSpotId     String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  listing      SoukListing      @relation(fields: [listingId], references: [id])
  handover     SoukHandover?
  ratings      SoukRating[]
  disputes     SoukDispute[]
  safeMeetSpot SoukSafeMeetSpot? @relation(fields: [safeMeetSpotId], references: [id])

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("offers")
  @@schema("tenant_soukelkanto")
}

model SoukHandover {
  id                String     @id @default(uuid())
  offerId           String     @unique
  buyerConfirmedAt  DateTime?
  sellerConfirmedAt DateTime?
  bothConfirmedAt   DateTime?
  ratingWindowEndsAt DateTime?
  createdAt         DateTime   @default(now())

  offer SoukOffer @relation(fields: [offerId], references: [id])

  @@map("handovers")
  @@schema("tenant_soukelkanto")
}

model SoukRating {
  id             String    @id @default(uuid())
  offerId        String
  raterId        String                                        // FK → core.GlobalUser
  targetId       String                                        // FK → core.GlobalUser
  score          Int                                           // 1-5
  comment        String?   @db.Text
  mappedSeverity Int                                           // 0/0/1/3/5 from score 5/4/3/2/1
  reportRowId    String?                                         // FK to core.EcosystemSharedReport.id
  createdAt      DateTime  @default(now())

  offer SoukOffer @relation(fields: [offerId], references: [id])

  @@unique([offerId, raterId])
  @@index([targetId])
  @@map("ratings")
  @@schema("tenant_soukelkanto")
}

model SoukFavorite {
  id        String      @id @default(uuid())
  userId    String                                                  // FK → core.GlobalUser
  listingId String
  createdAt DateTime    @default(now())

  listing SoukListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
  @@schema("tenant_soukelkanto")
}

model SoukSafeMeetSpot {
  id          String      @id @default(uuid())
  name        String      @db.VarChar(120)
  nameAr      String      @db.VarChar(120)
  district    String      @db.VarChar(64)
  latitude    Float
  longitude   Float
  description String?     @db.Text
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  offers SoukOffer[]

  @@index([district])
  @@map("safe_meet_spots")
  @@schema("tenant_soukelkanto")
}

enum SoukCategory {
  FURNITURE
  ELECTRONICS
  APPLIANCES
  FASHION
  KIDS_TOYS
  KIDS_CLOTHING
  KIDS_GEAR
  BOOKS_MEDIA
  SPORTS_OUTDOOR
  HOME_DECOR
  KITCHEN_DINING
  BABY_MATERNITY
  MOBILE_TABLETS
  VINTAGE_COLLECTIBLES
  MOVING_BUNDLE
  OTHER

  @@schema("tenant_soukelkanto")
}

enum SoukCondition {
  NEW_WITH_TAGS
  LIKE_NEW
  GOOD
  FAIR
  NEEDS_REPAIR
  FOR_PARTS

  @@schema("tenant_soukelkanto")
}

enum SoukListingStatus {
  ACTIVE
  RESERVED
  SOLD
  PENDING_REVIEW
  REMOVED
  EXPIRED

  @@schema("tenant_soukelkanto")
}

enum SoukOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  COUNTERED
  WITHDRAWN
  EXPIRED
  HANDOVER_PENDING
  CONFIRMED
  CLOSED
  CANCELLED

  @@schema("tenant_soukelkanto")
}

enum SoukDisputeReason {
  ITEM_NOT_AS_DESCRIBED
  ITEM_DEFECTIVE
  NO_SHOW
  PAYMENT_ISSUE
  COUNTERFEIT
  SELLER_BACKED_OUT
  BUYER_BACKED_OUT
  SAFETY_CONCERN
  OTHER

  @@schema("tenant_soukelkanto")
}

enum SoukDisputeStatus {
  OPEN
  RESOLVED
  REJECTED

  @@schema("tenant_soukelkanto")
}

model SoukDispute {
  id          String           @id @default(uuid())
  offerId     String
  filedById   String
  againstId   String
  reason      SoukDisputeReason
  description String?           @db.Text
  evidenceR2Key String?
  status      SoukDisputeStatus @default(OPEN)
  resolvedAt  DateTime?
  resolvedById String?
  resolution  String?           @db.Text
  reportRowId String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  offer SoukOffer @relation(fields: [offerId], references: [id])

  @@unique([offerId]) // one OPEN dispute per offer
  @@index([filedById])
  @@index([againstId])
  @@index([status])
  @@map("disputes")
  @@schema("tenant_soukelkanto")
}

// ─────────────── tenant_life — Madinty Life ───────────────

enum LifeLocationType {
  CITY
  DISTRICT
  BLOCK
  GROUP
  PARK
  BUILDING
  MALL
  STORE
  SERVICE_AREA
  STREET
  PARKING
  OTHER

  @@schema("tenant_life")
}

model LifeLocation {
  id            String           @id @default(uuid())
  name          String           @db.VarChar(120)
  nameAr        String           @db.VarChar(120)
  description   String?          @db.Text
  descriptionAr String?          @db.Text @map("description_ar")
  
  // Geographic coordinates for mapping
  latitude    Float?
  longitude   Float?
  
  // Hierarchical Self-Relation (Infinite Nesting)
  parentId    String?          @map("parent_id")
  parent      LifeLocation?    @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    LifeLocation[]   @relation("LocationHierarchy")
  
  type        LifeLocationType
  
  // Flexible metadata (opening hours, phone, amenities, website, tags)
  metadata    Json             @default("{}")
  
  // Storefront relations
  items       LifeLocationItem[]
  bookings    LifeBooking[]
  posts       LifePost[]
  photos      LifeLocationPhoto[]
  
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([type])
  @@map("locations")
  @@schema("tenant_life")
}

// ─────────────── Madinty Life Storefront Capabilities ───────────────

enum LifeItemType {
  MENU_ITEM
  PRODUCT
  EXHIBIT
  MEDICAL_SERVICE

  @@schema("tenant_life")
}

enum LifeBookingType {
  TABLE_RESERVATION
  CLINIC_APPOINTMENT
  PRODUCT_ORDER

  @@schema("tenant_life")
}

enum LifeBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED

  @@schema("tenant_life")
}

model LifeLocationItem {
  id            String       @id @default(uuid())
  locationId    String       @map("location_id")
  location      LifeLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  title         String       @db.VarChar(120)
  titleAr       String?      @db.VarChar(120) @map("title_ar")
  description   String?      @db.Text
  descriptionAr String?      @db.Text @map("description_ar")
  price       Float?
  imageUrl    String?      @map("image_url")
  category    String?      @db.VarChar(60)
  isAvailable Boolean      @default(true) @map("is_available")
  type        LifeItemType
  metadata    Json         @default("{}")
  
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([locationId])
  @@index([type])
  @@map("location_items")
  @@schema("tenant_life")
}

model LifeBooking {
  id            String            @id @default(uuid())
  locationId    String            @map("location_id")
  location      LifeLocation      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  customerName  String            @map("customer_name") @db.VarChar(100)
  customerPhone String            @map("customer_phone") @db.VarChar(20)
  dateTime      DateTime?         @map("date_time")
  status        LifeBookingStatus @default(PENDING)
  type          LifeBookingType
  notes         String?           @db.Text
  metadata      Json              @default("{}")
  
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([locationId])
  @@index([status])
  @@index([type])
  @@map("location_bookings")
  @@schema("tenant_life")
}

model LifePost {
  id          String       @id @default(uuid())
  locationId  String       @map("location_id")
  location    LifeLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  title       String       @db.VarChar(150)
  content     String       @db.Text
  imageUrl    String?      @map("image_url")
  isActive    Boolean      @default(true) @map("is_active")
  
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([locationId])
  @@index([isActive])
  @@map("location_posts")
  @@schema("tenant_life")
}

model LifeLocationPhoto {
  id          String       @id @default(uuid())
  locationId  String       @map("location_id")
  location    LifeLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  url         String
  caption     String?      @db.VarChar(200)
  position    Int          @default(0)
  
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([locationId])
  @@map("location_photos")
  @@schema("tenant_life")
}

// =====================================================
// tenant_express — Madinty Express delivery system
// =====================================================

model ExpressCourier {
  id              String   @id @default(uuid())
  userId          String   @unique                                      // FK to core.GlobalUser.id (logical)
  name            String   @db.VarChar(120)
  phone           String   @db.VarChar(30)
  vehicleType     String   @db.VarChar(40)                              // "BICYCLE" | "MOTORCYCLE" | "CAR" | "SCOOTER" | "WALKING"
  nationalId      String   @unique @db.VarChar(30)
  nationalIdPhoto String?  @db.Text
  personalPhoto   String?  @db.Text
  status          String   @default("PENDING")                          // "PENDING" | "APPROVED" | "REJECTED"
  isOnline        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("couriers")
  @@schema("tenant_express")
}

model ExpressDeliveryRequest {
  id                String   @id @default(uuid())
  kitchenBusinessId String   @db.VarChar(60)                              // Logical FK to tenant_kitchen.KitchenBusiness.id
  kitchenName       String   @db.VarChar(120)
  deliveryPoint     String   @db.Text                                     // Delivery destination inside Madinaty
  recipientName     String   @db.VarChar(120)
  recipientPhone    String   @db.VarChar(30)
  notes             String?  @db.Text
  status            String   @default("PENDING")                          // "PENDING" | "ACCEPTED" | "PICKED_UP" | "DELIVERED" | "CANCELLED"
  courierId         String?  @db.VarChar(60)                              // Logical FK to ExpressCourier.id
  courierName       String?  @db.VarChar(120)
  courierPhone      String?  @db.VarChar(30)
  acceptedAt        DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("delivery_requests")
  @@schema("tenant_express")
}
