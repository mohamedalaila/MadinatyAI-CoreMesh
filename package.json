{
  "name": "madinatyai-coremesh",
  "version": "0.1.0",
  "private": true,
  "description": "MadinatyAI Ecosystem Hub (نواة مدينتي) - multi-tenant core backend",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register apps/core-hub/src/main.ts",
    "build": "tsc -p apps/core-hub/tsconfig.app.json && tsc-alias -p apps/core-hub/tsconfig.app.json",
    "start:prod": "node dist/apps/core-hub/src/main.js",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "format": "prettier --write \"{apps,libs}/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@google/generative-ai": "0.21.0",
    "@nestjs/bullmq": "10.2.1",
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "axios": "1.7.9",
    "bullmq": "5.34.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "^1.4.7",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.2.0",
    "ioredis": "5.4.2",
    "pino": "^8.21.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "sonic-boom": "^4.2.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.15",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.2",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "nx": "20.3.0",
    "prettier": "3.4.2",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.8.10",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.3"
  }
}
